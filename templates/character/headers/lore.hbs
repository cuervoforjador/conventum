<div class="_combo _fields">
    <label>{{localize 'common.reino'}}:</label>
    {{#unless (eq info.reino.id '')}}
    <a data-action="_showItem" data-id="{{info.reino.id}}">
    {{/unless}}
        <label class="_field">{{info.reino.label}}</label>
    {{#unless (eq info.reino.id '')}}
    </a>
    {{/unless}}
    {{#if isEditable}}
    <button type="button"
            class="icon fas fa-edit" 
            data-action="_editLore" 
            data-lore="reino"
            data-tooltip="{{localize 'common.editarReino'}}">
    </button>
    {{/if}}
</div>    

