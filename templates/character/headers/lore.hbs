{{#if configRULES.limpiezaSangre}}
<div class="_combo _fields">
    <label>{{localize 'common.limpiezaSangre'}}:</label>
    {{#if isEditable}}
    <input type="number" 
            name="system.info.limpiezaSangre" 
            value="{{system.info.limpiezaSangre}}" 
            min="0" 
            max="100"
            class="_xsSize _center"> 
    <label>%</label>           
    {{else}}
    <label class="_field">{{system.info.limpiezaSangre}} %</label>
    {{/if}}
</div>
{{/if}}

